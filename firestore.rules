rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.isAdmin == true;
    }

    function isChatAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.isChatAdmin == true;
    }

    function userProtectedKeysChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'uid',
        'email',
        'emailLower',
        'createdAt',
        'isAdmin',
        'isChatAdmin',
        'isStaff',
        'isBanned',
        'banReason',
        'banExpiry',
        'merchantExpiry',
        'mentorExpiry'
      ]);
    }

    function canIncrementUnreadFor(userId) {
      return signedIn()
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'unreadMessages',
          'unreadMessages.' + request.auth.uid + '_' + userId,
          'unreadMessages.' + userId + '_' + request.auth.uid
        ]);
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chatrooms/$(roomId))
        && get(/databases/$(database)/documents/chatrooms/$(roomId)).data.participants.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && (request.resource.data.isAdmin == false || !('isAdmin' in request.resource.data))
        && (request.resource.data.isChatAdmin == false || !('isChatAdmin' in request.resource.data));
      allow update: if isAdmin()
        || (signedIn() && request.auth.uid == userId && !userProtectedKeysChanged())
        || canIncrementUnreadFor(userId);
      allow delete: if isAdmin();
    }

    match /usernameIndex/{usernameLower} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /chatrooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn() && (
        isAdmin()
        || isChatAdmin()
        || resource.data.ownerId == request.auth.uid
        || resource.data.moderators.hasAny([request.auth.uid])
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'lastActivity'])
          && (
            resource.data.participants.hasAny([request.auth.uid])
            || request.resource.data.participants.hasAny([request.auth.uid])
          )
        )
      );
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);
    }

    match /chatroomNames/{slug} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if signedIn() && (
        isAdmin()
        || resource.data.participants.hasAny([request.auth.uid])
        || resource.data.from == request.auth.uid
        || resource.data.to == request.auth.uid
      );
      allow create: if signedIn() && (
        isAdmin()
        || request.resource.data.participants.hasAny([request.auth.uid])
        || request.resource.data.from == request.auth.uid
        || request.resource.data.to == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /userAlerts/{alertId} {
      allow read: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if signedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /emailInvites/{inviteId} {
      allow read: if signedIn() && (
        isAdmin()
        || resource.data.inviterUid == request.auth.uid
        || resource.data.registeredUserId == request.auth.uid
      );
      allow create: if signedIn() && (isAdmin() || request.resource.data.inviterUid == request.auth.uid);
      allow update: if signedIn() && (
        isAdmin()
        || resource.data.inviterUid == request.auth.uid
        || request.resource.data.registeredUserId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /giftContests/{contestId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isChatAdmin();
      allow update: if isAdmin() || isChatAdmin() || (
        signedIn()
        && resource.data.isActive == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['giftStats', 'inviteStats', 'lotteryEntries'])
      );
      allow delete: if isAdmin();
    }

    match /contestMeta/{roomId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isChatAdmin();
    }

    match /redeemCodes/{codeId} {
      allow read: if signedIn();
      allow create: if signedIn() && (
        isAdmin()
        || isChatAdmin()
        || (
          'roomId' in request.resource.data
          && request.resource.data.roomId is string
          && isRoomParticipant(request.resource.data.roomId)
        )
      );
      allow update: if signedIn() && (
        isAdmin()
        || isChatAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redeemedBy'])
      );
      allow delete: if isAdmin();
    }

    match /redeemCodeMeta/{roomId} {
      allow read, write: if signedIn();
    }

    match /vouchers/{voucherId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        signedIn()
        && resource.data.redeemed != true
        && request.resource.data.redeemed == true
        && request.resource.data.redeemedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'redeemed',
          'redeemedBy',
          'redeemedByUsername',
          'redeemedAt'
        ])
      );
    }

    match /voucherBatches/{batchId} {
      allow read, write: if isAdmin();
    }

    match /profileLikes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.likerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /petFeedingsDaily/{docId} {
      allow read, write: if signedIn();
    }

    match /leaderboardMonthly/{kindMonth}/users/{userId} {
      allow read: if signedIn();
      allow write: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /gameEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /redeemEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /meta/{docId} {
      allow read: if signedIn();
      allow create: if signedIn() && docId == 'roomsInitialized';
      allow update, delete: if isAdmin();
    }

    match /metaLocks/{lockId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
